# HubSpot
HUBSPOT_ACCESS_TOKEN=pat-xxx          # HubSpot private app access token
HUBSPOT_PORTAL_ID=xxxxxxx            # HubSpot account ID (numeric)

# Cal.com
NEXT_PUBLIC_CALCOM_USERNAME=dativo    # Cal.com username or team slug
NEXT_PUBLIC_CALCOM_EVENT_SLUG=demo    # The event type slug (e.g., "demo" for a 30-min demo call)

# Resend (for email notifications)
RESEND_API_KEY=re_xxx                 # Resend API key
NOTIFICATION_EMAIL=hello@dativo.dev   # Where to send form submission notifications

# Optional: HubSpot tracking script (enables page visit tracking per contact)
# Only enable if you have a cookie consent banner in place
# NEXT_PUBLIC_HUBSPOT_PORTAL_ID=xxxxxxx
